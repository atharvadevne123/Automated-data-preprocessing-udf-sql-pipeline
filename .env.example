# ============================================================
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to version control.
# ============================================================

# ----------------------------------------------------------
# Snowflake connection (all required)
# ----------------------------------------------------------
# Account identifier, e.g. "xy12345.us-east-1" or "orgname-accountname"
SNOWFLAKE_ACCOUNT=your_account_here

# Snowflake username
SNOWFLAKE_USER=your_user_here

# Password or key-pair passphrase
SNOWFLAKE_PASSWORD=your_password_here

# Virtual warehouse for query execution
SNOWFLAKE_WAREHOUSE=your_warehouse_here

# Target database
SNOWFLAKE_DATABASE=your_database_here

# Target schema (defaults to PUBLIC if not set)
SNOWFLAKE_SCHEMA=PUBLIC

# Optional: Snowflake role to assume on connection
# SNOWFLAKE_ROLE=SYSADMIN

# ----------------------------------------------------------
# AWS S3 credentials (used in COPY INTO statements)
# ----------------------------------------------------------
AWS_KEY_ID=your_aws_key_id_here
AWS_SECRET_KEY=your_aws_secret_key_here
S3_BUCKET=your_bucket_name_here

# S3 key prefix under which split files are staged
S3_PREFIX=yelp/

# ----------------------------------------------------------
# Application settings
# ----------------------------------------------------------
# Logging level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
